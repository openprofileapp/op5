{
  "name": "openprofile",
  "version": "5.0.300-beta-build-cfeeba0",
  "description": "This is an example description",
  "keywords": [
    "example",
    "keyword"
  ],
  "author": "OpenProfile",
  "license": "OPPL",
  "type": "module",
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs && pm2 monit",
    "dev": "pm2 start dev.ecosystem.config.cjs && pm2 monit",
    "stop": "pm2 stop all && pm2 kill",
    "sandbox": "tsx sandbox/%npm_config_name%.test.ts",
    "backup": "tsx dev/backup.ts",
    "update": "npm update && cd src-tauri && cargo update && cd ../",
    "build": "tsx dev/node/buildApp.mts",
    "clean": "rimraf dist && rimraf logs",
    "sync": "tsx dev/syncConfig.ts",
    "translate": "tsx dev/translateLocales.ts",
    "minify": "npx esbuild \"dist/**/*.js\" --format=esm --minify --banner:js=\"/* This file is part of OpenProfile. Copyright (c) 2017-2026 OpenProfile. All rights reserved. */\" --outdir=dist --allow-overwrite",
    "copy:ssl": "cpx ssl/**/* dist/ssl",
    "copy:public": "cpx public/**/* dist/public",
    "copy:package": "cpx package.json dist",
    "copy:env": "cpx .env dist",
    "copy:ecosystem": "cpx ecosystem.config.cjs dist",
    "publish:npm": "cd packages/node && npm publish && cd ../../",
    "build:npm": "cd packages/node && tsx ../../dev/node/buildNodePackage.mts && cd ../../",
    "dev:app": "tauri dev",
    "build:app:windows": "tauri build --target x86_64-pc-windows-msvc --no-bundle",
    "package:app:windows": "cmd /c \"\"C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe\" inno.iss\"",
    "init": "npm install && npm install -g pm2 && shx cp .env.example .env && shx mv ssl/dev.crt.example ssl/dev.crt && shx mv ssl/dev.key.example ssl/dev.key && shx mv ssl/prod.crt.example ssl/prod.crt && shx mv ssl/prod.key.example ssl/prod.key && rimraf --glob \"**/DELETE_ME\" && npm run update"
  },
  "dependencies": {
    "@sapphire/stopwatch": "^1.5.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2",
    "axios": "^1.15.0",
