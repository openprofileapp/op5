    "cron-parser": "^5.5.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.4",
    "http-proxy": "^1.18.1",
    "i18next": "^26.0.8",
    "i18next-http-backend": "^3.0.6",
    "kage-library": "^1.0.15",
    "luxon": "^3.7.2",
